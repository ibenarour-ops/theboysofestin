const Professor = require('../models/professor.model');

const getProfessors = async (req, res) => {
  try {
    const filter = {};
    if (req.query.department) filter.department = req.query.department;
    const professors = await Professor.find(filter).populate('user', 'firstName lastName email profilePicture');
    res.json(professors);
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
};

const getProfessor = async (req, res) => {
  try {
    const professor = await Professor.findById(req.params.id).populate('user', 'firstName lastName email profilePicture');
    if (!professor) return res.status(404).json({ error: 'Professor not found' });
    res.json(professor);
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
};

const createProfessor = async (req, res) => {
  try {
    const professor = await Professor.create(req.body);
    res.status(201).json(professor);
  } catch (err) {
    res.status(400).json({ error: err.message });
  }
};

const updateProfessor = async (req, res) => {
  try {
    const professor = await Professor.findByIdAndUpdate(req.params.id, req.body, { new: true });
    if (!professor) return res.status(404).json({ error: 'Professor not found' });
    res.json(professor);
  } catch (err) {
    res.status(400).json({ error: err.message });
  }
};

const getTodayAttendance = async (req, res) => {
  try {
    const today = new Date().toISOString().split('T')[0];
    const professors = await Professor.find().populate('user', 'firstName lastName email profilePicture');
    const result = professors.map(prof => {
      const log = prof.attendanceLogs.find(l => l.date === today);
      return {
        professor: prof,
        todayStatus: log ? log.status : 'unknown',
        note: log ? log.note : '',
      };
    });
    res.json(result);
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
};

const markAttendance = async (req, res) => {
  try {
    const { date, status, note } = req.body;
    const professor = await Professor.findById(req.params.id);
    if (!professor) return res.status(404).json({ error: 'Professor not found' });

    const today = date || new Date().toISOString().split('T')[0];
    const existingLog = professor.attendanceLogs.find(l => l.date === today);

    if (existingLog) {
      existingLog.status = status;
      existingLog.note = note || '';
      existingLog.markedBy = req.user._id;
      existingLog.markedAt = new Date();
    } else {
      professor.attendanceLogs.push({ date: today, status, note: note || '', markedBy: req.user._id });
    }

    await professor.save();
    res.json({ message: 'Attendance marked successfully', professor });
  } catch (err) {
    res.status(400).json({ error: err.message });
  }
};

module.exports = { getProfessors, getProfessor, createProfessor, updateProfessor, getTodayAttendance, markAttendance };
